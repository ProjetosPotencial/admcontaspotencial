NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Opcional: só necessário se for usar o envio de boletos para o Google Drive.
# Veja o passo a passo no README na seção "Google Drive (opcional)".
# Vem do arquivo JSON baixado em APIs e Serviços > Credenciais > ID do
# cliente OAuth (tipo "Aplicativo Web"), não da conta de serviço.
GOOGLE_OAUTH_CLIENT_ID=algo.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx
GOOGLE_OAUTH_REDIRECT_URI=https://SEU-APP.vercel.app/api/google-auth/callback
# Esse aqui só é gerado depois: um admin visita /api/google-auth logado no
# app, autoriza no Google com a conta dona da pasta, e cola o token mostrado
# na tela aqui.
GOOGLE_OAUTH_REFRESH_TOKEN=

GOOGLE_DRIVE_FOLDER_ID=id-da-pasta-no-drive

# Opcional: só necessário para o aviso diário no Slack de contas vencendo/atrasadas.
SUPABASE_SERVICE_ROLE_KEY=a-chave-de-servico-do-supabase-nunca-a-anon-key
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/SEU/WEBHOOK/AQUI
# Protege a rota de notificacao contra chamada publica. Qualquer texto serve,
# so precisa ser o mesmo aqui e nas configuracoes de Cron Jobs do projeto na Vercel.
CRON_SECRET=escolha-uma-frase-aleatoria-longa

# Opcional: só necessário para o assistente de IA na tela de Contratos.
# Pega em console.anthropic.com > API Keys.
ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui

# Opcional: so necessario para a Caixa de Entrada (importar boletos de uma
# pasta do Google Drive automaticamente). Usa as mesmas credenciais OAuth
# do Drive que voce ja configurou, so precisa dessa variavel a mais:
GOOGLE_DRIVE_INBOX_FOLDER_ID=id-da-pasta-de-entrada-no-drive
